# Optional: enable API key auth
# ETHLLAMA_API_KEY=your-secret-here

# Optional: HTTPS
# ETHLLAMA_SSL_KEYFILE=/etc/ethllama/server.key
# ETHLLAMA_SSL_CERTFILE=/etc/ethllama/server.crt
# ETHLLAMA_SSL_KEYFILE_PASSWORD=
# ETHLLAMA_SSL_CA_CERTS=

# Optional: install path hint (used by some debugging tools only)
# ETHLLAMA_HOME=/home/youruser/.local/share/uv/tools/ethicallama
